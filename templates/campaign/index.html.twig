{% extends 'base.html.twig' %}

{% block title %}Campaigns{% endblock %}

{% block body %}
    <h1>My Campaigns</h1>

    <table class="table">
        <thead>
        <tr>
            <th>Id</th>
            <th>Title</th>
            <th>Description</th>
            <th>actions</th>
        </tr>
        </thead>
        <tbody>
        {% for myCampaign in myCampaigns %}
            <tr>
                <td>{{ myCampaign.id }}</td>
                <td>{{ myCampaign.title }}</td>
                <td>{{ myCampaign.description }}</td>
                <td>
                    <a href="{{ path('app_campaign_show', {'campaign': myCampaign.id}) }}">show</a>
                    <a href="{{ path('app_campaign_edit', {'campaign': myCampaign.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <h1>Campaigns</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>Description</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for campaign in campaigns %}
            <tr>
                <td>{{ campaign.id }}</td>
                <td>{{ campaign.title }}</td>
                <td>{{ campaign.description }}</td>
                <td>
                    <a href="{{ path('app_campaign_show', {'campaign': campaign.id}) }}">show</a>
                    <a href="{{ path('app_campaign_edit', {'campaign': campaign.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_campaign_new') }}">Create new</a>
{% endblock %}
